<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAlertType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scream Detected"
                android:textSize="18sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvAlertLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@id/tvAlertType"
                app:layout_constraintBottom_toBottomOf="@id/tvAlertType"
                app:layout_constraintStart_toEndOf="@id/tvAlertType"/>

            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvAlertType"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: ACTIVE"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvAlertTime"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvAlertLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0, 0.0"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvAlertStatus"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvAlertConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90% confidence"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvAlertLocation"
                app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/ivEmailSent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/sym_action_email"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/ivSmsSent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/sym_action_chat"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"/>

                <ImageView
                    android:id="@+id/ivWhatsappSent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/sym_contact_card"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>
