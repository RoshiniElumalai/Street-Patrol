<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvProtectionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INACTIVE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvProtectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection: INACTIVE"
                app:layout_constraintTop_toBottomOf="@id/tvProtectionBadge"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchProtection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <Button
                android:id="@+id/btnSos"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SOS"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus"/>

            <Button
                android:id="@+id/btnSafeWalk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start SafeWalk"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnSos"/>

            <ProgressBar
                android:id="@+id/audioLevelBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnSafeWalk"/>

            <TextView
                android:id="@+id/tvAudioLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 dB"
                app:layout_constraintTop_toBottomOf="@id/audioLevelBar"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvCurrentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location: Unknown"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvAudioLevel"/>

            <TextView
                android:id="@+id/tvLastAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Alert: Never"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvCurrentLocation"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvAlertCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                app:layout_constraintTop_toTopOf="@id/tvLastAlert"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- System Health Dashboard -->
            <LinearLayout
                android:id="@+id/layoutSystemHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvLastAlert">

                <TextView
                    android:id="@+id/tvMicStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Microphone: OK"/>
                <TextView
                    android:id="@+id/tvGpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS: OK"/>
                <TextView
                    android:id="@+id/tvInternetStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Internet: OK"/>
                <TextView
                    android:id="@+id/tvNotificationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications: OK"/>
                <TextView
                    android:id="@+id/tvDatabaseStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Database: OK"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnNearbySafety"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nearby Safety Scanner"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/layoutSystemHealth"/>

            <Button
                android:id="@+id/btnEvidenceVault"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Evidence Vault"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnNearbySafety"/>

            <Button
                android:id="@+id/btnSystemHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System Health"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnEvidenceVault"/>

            <Button
                android:id="@+id/btnFakeCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fake Call"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnSystemHealth"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
