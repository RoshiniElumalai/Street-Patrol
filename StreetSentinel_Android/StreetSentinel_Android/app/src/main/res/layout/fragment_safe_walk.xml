<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mapView"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/layoutControls" />

        <LinearLayout
            android:id="@+id/layoutControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Start Walk Config -->
            <LinearLayout
                android:id="@+id/layoutStartWalk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/etDestination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter destination"
                    android:inputType="text"/>

                <EditText
                    android:id="@+id/etCheckInTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Check-in time (minutes)"
                    android:inputType="number"
                    android:text="30"/>

                <Button
                    android:id="@+id/btnStartWalk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start SafeWalk"/>
            </LinearLayout>

            <!-- Walk Active Info -->
            <LinearLayout
                android:id="@+id/layoutWalkInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvDestination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destination: "/>

                <TextView
                    android:id="@+id/tvWalkStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: ACTIVE"/>

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance: 0 m"/>

                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA: 0 min"/>

                <TextView
                    android:id="@+id/tvCheckInTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check-in in: 30:00"/>

                <Button
                    android:id="@+id/btnCheckIn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Check In Now"/>

                <Button
                    android:id="@+id/btnShareLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share Location"/>

                <Button
                    android:id="@+id/btnEndWalk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="End SafeWalk"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
